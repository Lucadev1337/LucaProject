{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "A customer's car detailing booking.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string", "description": "Full name of the customer." },
        "email": { "type": "string", "format": "email", "description": "Email address." },
        "phone": { "type": "string", "description": "Phone number." },
        "service": { "type": "string", "description": "Detailing service name." },
        "date": { "type": "string", "description": "Date of the booking (YYYY-MM-DD)." },
        "timeSlot": { "type": "string", "description": "Selected time slot (e.g., 09:00)." },
        "location": { "type": "string", "description": "Customer's location for the mobile service." },
        "fuelFee": { "type": "number", "description": "Calculated fuel/distance fee." },
        "distance": { "type": "number", "description": "Calculated distance in KM." },
        "notes": { "type": "string", "description": "Optional notes for the booking." },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"], "description": "Current status of the booking." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was created." },
        "uid": { "type": "string", "description": "Optional user ID if logged in, but public bookings might not have this." },
        "addons": { "type": "array", "items": { "type": "string" }, "description": "List of selected addon IDs." }
      },
      "required": ["customerName", "email", "phone", "service", "date", "timeSlot", "location", "status", "createdAt"]
    },
    "Addon": {
      "title": "Addon",
      "description": "An additional service that can be added to a booking.",
      "type": "object",
      "properties": {
        "nameGE": { "type": "string", "description": "Name of the addon in Georgian." },
        "nameEN": { "type": "string", "description": "Name of the addon in English." },
        "descriptionGE": { "type": "string", "description": "Details of the addon in Georgian." },
        "descriptionEN": { "type": "string", "description": "Details of the addon in English." },
        "price": { "type": "number", "description": "Price of the addon." },
        "active": { "type": "boolean", "description": "Whether the addon is available for booking." }
      },
      "required": ["nameGE", "nameEN", "price", "active"]
    },
    "Availability": {
      "title": "Availability",
      "description": "Available time slots for a specific date.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "description": "The date (YYYY-MM-DD)." },
        "slots": { "type": "array", "items": { "type": "string" }, "description": "List of available time slots." }
      },
      "required": ["date", "slots"]
    },
    "Verification": {
      "title": "Verification",
      "description": "Email verification code for booking finalization.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "Email address being verified." },
        "code": { "type": "string", "description": "6-digit verification code." },
        "expires": { "type": "number", "description": "Expiration timestamp (ms)." },
        "used": { "type": "boolean", "description": "Whether the code has been used." }
      },
      "required": ["email", "code", "expires", "used"]
    },
    "PricingSettings": {
      "title": "PricingSettings",
      "description": "Global pricing and sales settings.",
      "type": "object",
      "properties": {
        "price": { "type": "number", "description": "Price for the detailing service." },
        "pricePerKm": { "type": "number", "description": "Cost per kilometer for the fuel fee." },
        "baseLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "description": "Base location coordinates for distance calculations."
        },
        "salePercentage": { "type": "number", "description": "Sale percentage (e.g., 20 for 20% off)." },
        "isSaleActive": { "type": "boolean", "description": "Whether the sale is currently active." },
        "heroReviews": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "imageUrl": { "type": "string", "description": "URL of the reviewer avatar." },
              "link": { "type": "string", "description": "Link to the review or social profile." }
            }
          },
          "description": "List of reviewer avatars with links for the hero section."
        }
      },
      "required": ["price", "salePercentage", "isSaleActive"]
    },
    "PromoCode": {
      "title": "PromoCode",
      "description": "A discount code for bookings.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "The promo code string (e.g., SAVE20)." },
        "discount": { "type": "number", "description": "Discount percentage (e.g., 20 for 20% off)." },
        "active": { "type": "boolean", "description": "Whether the code is currently active." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the code was created." }
      },
      "required": ["code", "discount", "active", "createdAt"]
    },
    "Client": {
      "title": "Client",
      "description": "A customer profile for tracking cars and history.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the client." },
        "phone": { "type": "string", "description": "Primary phone number." },
        "email": { "type": "string", "format": "email", "description": "Optional email address." },
        "notes": { "type": "string", "description": "General notes about the client." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the client was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the client was last updated." }
      },
      "required": ["fullName", "phone", "createdAt", "updatedAt"]
    },
    "Car": {
      "title": "Car",
      "description": "A vehicle owned by a client.",
      "type": "object",
      "properties": {
        "brand": { "type": "string", "description": "Car brand (e.g., BMW)." },
        "model": { "type": "string", "description": "Car model (e.g., X5)." },
        "year": { "type": "string", "description": "Car year (optional)." },
        "licensePlate": { "type": "string", "description": "Car license plate." },
        "color": { "type": "string", "description": "Car color (optional)." },
        "notes": { "type": "string", "description": "Notes about the specific car." }
      },
      "required": ["brand", "model", "licensePlate"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of all customer bookings."
    },
    "/availability/{date}": {
      "schema": "Availability",
      "description": "Available slots per date."
    },
    "/verifications/{verificationId}": {
      "schema": "Verification",
      "description": "Temporary verification codes for email confirmation."
    },
    "/settings/pricing": {
      "schema": "PricingSettings",
      "description": "Global pricing configuration."
    },
    "/taken_slots/{slotId}": {
      "schema": "object",
      "description": "Publicly readable record of taken time slots to avoid PII exposure."
    },
    "/promo_codes/{codeId}": {
      "schema": "PromoCode",
      "description": "Collection of discount codes."
    },
    "/addons/{addonId}": {
      "schema": "Addon",
      "description": "Collection of add-on services."
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Collection of all clients."
    },
    "/clients/{clientId}/cars/{carId}": {
      "schema": "Car",
      "description": "List of cars owned by a client."
    }
  }
}
