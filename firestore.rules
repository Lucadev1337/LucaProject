rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email.matches("(?i)luca\\.mergell@gmail\\.com") || 
         request.auth.token.email == "Luca.mergell@gmail.com" || 
         request.auth.token.email == "luca.mergell@gmail.com") && 
        request.auth.token.email_verified == true;
    }
    match /bookings/{bookingId} {
      allow create: if true;
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['calendarSecret', 'verificationMethod', 'customerEmail']) &&
        request.resource.data.calendarSecret == "7f8a9b0c1d2e3f4g5h6i7j8k9l0m1n2o3p4q5r6s7t8u9v0w1x2y3z"
      );
      allow read, delete: if isAdmin();
      // Allow server-side calendar feed to list bookings using a system secret
      allow list: if request.query.limit <= 1000 && resource.data.calendarSecret == "7f8a9b0c1d2e3f4g5h6i7j8k9l0m1n2o3p4q5r6s7t8u9v0w1x2y3z";
    }
    match /availability/{date} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /taken_slots/{slotId} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }
    match /verification_codes/{email} {
      allow read, write: if true;
    }
    match /settings/pricing {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /promo_codes/{code} {
      allow get: if true;
      allow list, create, update, delete: if isAdmin();
    }
    match /calendar_events/{eventId} {
      // Server writes these
      allow create: if true;
      // Server reads these using the secret
      allow list: if request.query.limit <= 1000 && (resource.data.secret == "7f8a9b0c1d2e3f4g5h6i7j8k9l0m1n2o3p4q5r6s7t8u9v0w1x2y3z" || isAdmin());
      // Allow deletion by secret too
      allow delete: if (resource.data.secret == "7f8a9b0c1d2e3f4g5h6i7j8k9l0m1n2o3p4q5r6s7t8u9v0w1x2y3z" || isAdmin());
      allow get, update: if false;
    }
  }
}
